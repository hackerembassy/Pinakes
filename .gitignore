# ========================================
# CRITICAL: Environment & Credentials
# ========================================
.env
.env.*
!.env.example
.installed
config.local.php
config.local.sample.php
CLAUDE.md
.claude/

# ========================================
# CRITICAL: Database Backups & Archives
# ========================================
backups/*
!backups/.gitkeep
!backups/.htaccess
*.sql
!installer/database/*.sql
!installer/database/migrations/*.sql
*.backup
*.backup*
!/backups/.htaccess
!/storage/backups/.htaccess
*.bak
*.old
backup_*.sql
migration-*.php

# Temporary maintenance scripts
clean-*.sh
convert-*.php
export-*.php
fix-*.php
debug_*.php
test_*.php
router.php

# ========================================
# CRITICAL: Archives
# ========================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z
Archive.zip
old.sql

